ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_PAPER=true

# NewsAPI — 1 top headline per ticker in Telegram briefings
# Free key (100 req/day): https://newsapi.org/register
NEWSAPI_KEY=

# Telegram daily briefing (recommended)
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Start a chat with your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  to find your chat_id
TELEGRAM_BOT_TOKEN=your_key_here
TELEGRAM_CHAT_ID=your_key_here

# Optional additional alert channels
ALERT_EMAIL=
ALERT_WEBHOOK_URL=
